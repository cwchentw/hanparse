#!/bin/sh

CWD=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd) || exit 1

RULE_FILE="${CWD}/data/rules.json"
if ! [ -f "$RULE_FILE" ]; then
    echo "No rule file: $RULE_FILE" >&2
    exit 1
fi

COUNT="${CWD}/tools/rule-count"
if ! [ -x "$COUNT" ]; then
    echo "No rule count tool: $COUNT" >&2
    exit 1
fi

"$COUNT" "$RULE_FILE"